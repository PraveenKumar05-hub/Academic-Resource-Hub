PORT=5000
MONGO_URI=mongodb://localhost:27017/academic
JWT_SECRET=replace_with_a_strong_secret
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# SMTP config for Forgot Password OTP emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
SMTP_FROM="Academic Resource Hub <your_email@gmail.com>"

# Reminder notifications now use SMTP email (same config as above)

# Optional: override reminder timezone (default: Asia/Kolkata)
REMINDER_TIMEZONE=Asia/Kolkata
