{
  "name": "academic-resource-hub",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "concurrently -n server,client -c yellow,cyan \"npm run dev:server\" \"npm run dev:client\"",
    "dev:reset": "kill-port 5000 3000 3001 && npm run dev",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "start": "npm start --prefix server",
    "build": "npm run build --prefix client",
    "test": "npm test --prefix server",
    "install:all": "npm install --prefix server && npm install --prefix client && npm install"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "kill-port": "^2.0.1"
  }
}
